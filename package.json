{
  "name": "house-track",
  "version": "0.0.0",
  "private": true,
  "description": "999.md house & villa crawler — POC. Hourly cron, SQLite via Prisma, Chișinău + Durlești, sale only.",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "mcp:start": "node dist/mcp/server.js",
    "capture-session": "tsx scripts/capture-session.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.22.0",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "undici": "^6.21.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "pino-pretty": "^11.3.0",
    "playwright": "^1.49.0",
    "prettier": "^3.4.0",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yaml,yml,prisma}": [
      "prettier --write"
    ]
  }
}
