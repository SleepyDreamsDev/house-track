# Local dev. In Docker these come from docker-compose.yml.
DATABASE_URL=file:./data/crawler.db
LOG_LEVEL=info
TZ=Europe/Chisinau

# Optional override of the cron schedule (default: '0 * * * *' — every hour).
# CRON_SCHEDULE=0 * * * *

# Run a single sweep and exit (useful for ad-hoc testing).
# RUN_ONCE=1
