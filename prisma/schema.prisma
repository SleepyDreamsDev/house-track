// 999.md house crawler — POC schema.
// Source of truth: docs/poc-spec.md §"Database schema (Prisma)".

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  // `native` covers local dev (macOS/Linux). The two `*-openssl-3.0.x` targets
  // cover the Docker runtime image (node:22-bookworm-slim ships OpenSSL 3.0)
  // on both arm64 and amd64 hosts — without them the runtime image fails with
  // `could not locate the Query Engine for runtime "..."`.
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

model Listing {
  id            String   @id // 999.md numeric ID, e.g. "76543210"
  url           String   @unique
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime
  lastFetchedAt DateTime
  active        Boolean  @default(true) // false when no longer in index sweeps
  watchlist     Boolean  @default(false) // operator-flagged "always refresh me first"

  // Set when persistDetail has captured the typed filter-value triples below.
  // Null on legacy rows + on listings that have only ever been seen in the index.
  // The sweep's backfill step picks the oldest NULL rows each tick.
  filterValuesEnrichedAt DateTime?

  // Core fields (parsed)
  title       String
  priceEur    Int? // null if not parseable
  priceRaw    String? // original price string for audit
  rooms       Int?
  areaSqm     Float?
  landSqm     Float? // houses have land
  district    String? // raw value from breadcrumb/filter
  street      String?
  floors      Int? // for houses: number of floors
  yearBuilt   Int?
  heatingType String? // raw text
  description String? // full body text
  features    Json? // JSON array of feature tags
  imageUrls   Json? // JSON array of CDN URLs (NOT downloaded)
  sellerType  String? // private / agency (heuristic)
  postedAt    DateTime?
  bumpedAt    DateTime?

  // Versioning: track price/desc changes over time
  snapshots    ListingSnapshot[]
  filterValues ListingFilterValue[]

  @@index([active, lastSeenAt])
  @@index([priceEur])
  @@index([watchlist, lastFetchedAt]) // tiered-refresh rotation key
  @@index([active, lastFetchedAt]) // stale-rotation picker
}

// One row per filter triple observed on a listing's detail response.
// filterId groups features in 999.md's taxonomy; until we have a captured
// taxonomy query, parseDetail stores 0 (unknown) and queries match on
// (featureId, optionId).
model ListingFilterValue {
  id           Int     @id @default(autoincrement())
  listingId    String
  filterId     Int     @default(0)
  featureId    Int
  optionId     Int?
  textValue    String?
  numericValue Float?
  listing      Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([filterId, featureId, optionId])
  @@index([listingId])
  @@index([featureId, optionId])
}

model ListingSnapshot {
  id          Int      @id @default(autoincrement())
  listingId   String
  capturedAt  DateTime @default(now())
  priceEur    Int?
  description String?
  rawHtmlHash String // sha256 of normalized HTML, for change detection
  listing     Listing  @relation(fields: [listingId], references: [id])

  @@index([listingId, capturedAt])
}

model SweepRun {
  id              Int       @id @default(autoincrement())
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  status          String // ok / partial / failed / circuit_open / cancelled
  pagesFetched    Int       @default(0)
  detailsFetched  Int       @default(0)
  newListings     Int       @default(0)
  updatedListings Int       @default(0)
  errors          Json? // JSON array of {url, status, msg}
  source          String    @default("999.md") // data source identifier
  trigger         String    @default("cron") // cron / manual

  // Phase 0 of the UI redesign adds four nullable JSON columns; the crawler
  // populates them in later phases. Migration: 20260503235214_sweep_detail_columns.
  configSnapshot Json?
  pagesDetail    Json?
  detailsDetail  Json?
  eventLog       Json?

  // Two-tier cadence (PR 1 — plumbing). "legacy" rows are produced by the
  // current monolithic runSweep(); when sweep.mode flips to "two_tier",
  // index ticks write "index" and detail-trickle aggregates write "detail".
  kind String @default("legacy")
}

model Source {
  id                      Int      @id @default(autoincrement())
  slug                    String   @unique // e.g., "999md"
  name                    String   @default("") // human-readable name
  baseUrl                 String // base URL for the source
  adapterKey              String // adapter implementation key (currently only "999md" works)
  enabled                 Boolean  @default(true)
  politenessOverridesJson Json? // { baseDelayMs?, jitterMs?, detailDelayMs? }
  filterOverridesJson     Json? // { searchInput?, postFilter? }
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([slug])
}

model Setting {
  key       String   @id // e.g., "politeness.baseDelayMs"
  valueJson Json // store any JSON value
  updatedAt DateTime @updatedAt
}

// Per-listing fetch task queue for the two-tier cadence (PR 1 plumbing only;
// no producer/consumer wires this up yet — that lands in PR 2). The index
// ticker enqueues new+stale+backfill tasks; the detail trickle drains them
// in (priority, scheduledFor) order.
model FetchTask {
  id           Int      @id @default(autoincrement())
  listingId    String
  // 0=NEW, 1=WATCHLIST_REFRESH, 2=STALE_REFRESH, 3=BACKFILL
  priority     Int
  // Mirrors priority for operator readability: "new" | "watchlist" | "stale" | "backfill"
  reason       String
  enqueuedAt   DateTime @default(now())
  attemptCount Int      @default(0)
  lastError    String?
  scheduledFor DateTime @default(now())

  @@unique([listingId, reason])
  @@index([scheduledFor, priority])
}

// Persisted log of adaptive-throttle trigger events. The hot fetch path
// keeps rolling stats in memory; only the trigger itself is written here so
// the operator UI can render a "soft-throttled at HH:MM because X" timeline.
model ThrottleEvent {
  id          Int      @id @default(autoincrement())
  triggeredAt DateTime @default(now())
  // "5xx_rate" | "latency_spike" | "connection_reset"
  trigger     String
  durationMs  Int
  // JSON snapshot of the rolling-window stats at trigger time
  context     Json?

  @@index([triggeredAt])
}
